\",\"track_desc\":\"Transparent Performance\",\"partners\":\"Partners\",\"exchange_partners\":\"Exchange Partners\",\"exchange_desc\":\"Recommended Platforms\"},\"footer\":{\"tagline\":\"A fusion of multi-faceted AI market analysis and next-generation financial intelligence. We continue to pursue 'evidence-based predictions' in uncertain markets.\",\"col_platform\":\"Platform\",\"col_intelligence\":\"Intelligence\",\"col_trust\":\"Trust / Terms\",\"privacy\":\"Privacy Policy\",\"terms\":\"Terms of Service\",\"disclaimer\":\"Disclaimer: All financial predictions are AI-generated and do not constitute investment advice. Trading involves substantial risk.\"},\"sidebar\":{\"latest_intel\":\"Latest Intelligence\",\"fx\":\"FX\",\"crypto\":\"Crypto\",\"stocks\":\"Stocks\",\"bullish\":\"Bullish\",\"bearish\":\"Bearish\",\"track_record_title\":\"Global Analysis Performance\",\"win_rate\":\"Win Rate\",\"stats_desc\":\"Verified track record from {total} public reports\"},\"landing\":{\"hero_badge\":\"AI Intelligence v2.4 Active\",\"hero_title\":\"Uncovering the truth of financial markets through deep AI analysis.\",\"hero_desc\":\"Real-time multi-faceted market analysis powered by advanced proprietary algorithms. We integrate on-chain data, macroeconomic indicators, and institutional sentiment to provide highly transparent intelligence.\",\"terminal_access\":\"Terminal Access\",\"latest_reports\":\"Latest Reports\",\"signal_analysis_title\":\"Real-time Signal Analysis\",\"view_all_signals\":\"View all signals\",\"feature_terminal_title\":\"Market Terminal\",\"feature_terminal_desc\":\"Millisecond-level tick data updates and AI predictions. All the infrastructure professionals need, integrated into a single refined interface.\",\"view_details\":\"View Details\",\"feature_risk_title\":\"Risk Management Protocol\",\"feature_risk_desc\":\"Not just high-probability AI entries, but a rock-solid foundation for growth with multi-layered stop-loss algorithms to minimize drawdowns.\",\"
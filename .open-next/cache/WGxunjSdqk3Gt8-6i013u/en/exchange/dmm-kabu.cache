ysis Target\\\",\\\"buy\\\":\\\"Strong Buy\\\",\\\"sell\\\":\\\"Strong Sell\\\",\\\"neutral\\\":\\\"Neutral\\\",\\\"entry\\\":\\\"Entry\\\",\\\"tp\\\":\\\"Take Profit (TP)\\\",\\\"sl\\\":\\\"Stop Loss (SL)\\\",\\\"details\\\":\\\"In-depth Analysis\\\",\\\"start_trading\\\":\\\"Start Trading\\\",\\\"modal_title\\\":\\\"{pair} Signal Deep Analysis\\\",\\\"current_trend\\\":\\\"Current Trend\\\",\\\"uptrend\\\":\\\"Strong Uptrend\\\",\\\"downtrend\\\":\\\"Strong Downtrend\\\",\\\"range\\\":\\\"Range / Consolidation\\\",\\\"confidence\\\":\\\"AI Confidence Score\\\",\\\"engine_commentary\\\":\\\"AI Inference Engine Commentary\\\",\\\"strategy\\\":\\\"Recommended Strategy\\\",\\\"tp_target\\\":\\\"Take Profit Target\\\",\\\"sl_limit\\\":\\\"Stop Loss Limit\\\",\\\"analysis_desc_buy\\\":\\\"Solid support levels confirmed. High probability of mid-term rebound based on multi-dimensional correlation analysis of market volatility and price deviation.\\\",\\\"analysis_desc_sell\\\":\\\"Heavy resistance observed at current levels. High probability of entering a correction phase based on multi-dimensional correlation analysis.\\\"},\\\"reports\\\":{\\\"tldr\\\":\\\"Today's Summary (TL;DR)\\\",\\\"toc\\\":\\\"Table of Contents\\\",\\\"ai_conclusion\\\":\\\"AI Conclusion \\u0026 Action Plan\\\",\\\"next_step\\\":\\\"Next Step\\\",\\\"market_valuation\\\":\\\"Market Valuation\\\",\\\"realtime_price_desc\\\":\\\"Market reference price based on real-time API.\\\",\\\"latest_insights\\\":\\\"Latest Insights\\\"},\\\"ticker\\\":{\\\"gold\\\":\\\"GOLD\\\"},\\\"exchange\\\":{\\\"integrity_protocol\\\":\\\"AI Integrity Protocol\\\",\\\"selected_infrastructure\\\":\\\"Selected Infrastructure\\\",\\\"protocol_desc\\\":\\\"Synapse AI analysis algorithms constantly monitor the execution speed, spread stability, and transparency of each partner. We certify only those environments suitable for professional investing from an impartial third-party perspective.\\\",\\\"recommended_partner\\\":\\\"
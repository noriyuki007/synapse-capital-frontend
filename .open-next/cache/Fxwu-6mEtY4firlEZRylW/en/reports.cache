about\":\"About Us\",\"contact\":\"Contact\",\"system_active\":\"System Active\",\"live\":\"LIVE\",\"target\":\"Target\",\"all_reports\":\"All Reports\",\"no_reports\":\"No reports available\",\"intelligence_hub\":\"Intelligence Hub\",\"intelligence_reports\":\"Intelligence Reports\",\"reports_desc_long\":\"Latest market insights derived by Synapse AI. We provide a multi-faceted perspective integrating technical analysis, fundamentals, and on-chain data.\",\"prediction_history\":\"Prediction History\",\"page_indicator\":\"Page {current}/{total}\",\"prev\":\"Prev\",\"next\":\"Next\",\"back_to_reports\":\"Back to Reports\",\"read_more\":\"Read More\",\"target_pair_label\":\"Target: {pair}\",\"prediction_up\":\"Bullish\",\"prediction_down\":\"Bearish\",\"featured_intelligence\":\"Featured Intelligence\",\"performance_stats\":\"Performance Stats\",\"total_reports\":\"Total Reports\",\"win_rate_label\":\"Win Rate\",\"institutional_access_title\":\"Institutional Analysis for All\",\"institutional_access_desc\":\"Synapse AI monitors global markets 24/7, extracting only high-probability signals.\",\"fx\":\"FX\",\"crypto\":\"Crypto\",\"stocks\":\"Stocks\",\"share_this_report\":\"Share this report\",\"copy_link\":\"Copy Link\",\"link_copied\":\"Copied!\",\"partners\":\"Partners\",\"back_to_partners\":\"Back to Partners\",\"certified_unbiased\":\"Certified Unbiased\",\"not_found_title\":\"404 - Page Not Found\",\"not_found_desc\":\"The requested intelligence layer was not found. Please check if the URL is correct or if the report has been moved.\",\"back_to_home\":\"Back to Home\"},\"header\":{\"markets\":\"Market Terminal\",\"fx_pro\":\"FX Pro\",\"fx_desc\":\"AI Analysis for FX Markets\",\"stocks_pro\":\"Stocks Pro\",\"stocks_desc\":\"Global Equities Terminal\",\"crypto_pro\":\"Crypto Pro\",\"crypto_desc\":\"On-chain Insights\",\"intelligence\":\"Intelligence\",\"strategy_check\":\"AI Strategy Check\",\"strategy_desc\":\"Institutional Grade Analysis\",\"reports_desc\":\"AI Market Analysis Reports\",\"track_record\":\"Track Record\",\"track_desc\":\"Transparent Performance\",\"partners\":\"Partners\",\"exchange_partners\":\"Exchange Partners\",\"exchange_desc\":\"Recommended Platforms\"},\"footer\":{\"tagline\":\"A fusion of multi-faceted AI market analysis and next-generation financial intelligence. We continue to pursue 'evidence-based predictions' in uncertain markets.\",\"col_platform\":\"Platform\",\"col_intelligence\":\"Intelligence\",\"col_trust\":\"Trust / Terms\",\"privacy\":\"Privacy Policy\",\"terms\":\"Terms of Service\",\"disclaimer\":\"Disclaimer: All financial predictions are AI-generated and do not constitute investment advice. Trading involves substantial risk.\"},\"sidebar\":{\"latest_intel\":\"Latest Intelligence\",\"fx\":\"FX\",\"crypto\":\"Crypto\",\"stocks\":\"Stocks\",\"bullish\":\"Bullish\",\"bearish\":\"Bearish\",\"track_record_title\":\"Global Analysis Performance\",\"win_rate\":\"Win Rate\",\"stats_desc\":\"Verified track record from {total} public reports\"},\"landing\":{\"hero_badge\":\"AI Intelligence v2.4 Active\",\"hero_title\":\"Uncovering the truth of financial markets through deep AI analysis.\",\"hero_desc\":\"Real-time multi-faceted market analysis powered by advanced proprietary algorithms. We integrate on-chain data, macroeconomic indicators, and institutional sentiment to provide highly transparent intelligence.\",\"terminal_access\":\"Terminal Access\",\"latest_reports\":\"Latest Reports\",\"signal_analysis_title\":\"Real-time Signal Analysis\",\"view_all_signals\":\"View all signals\",\"feature_terminal_title\":\"Market Terminal\",\"feature_terminal_desc\":\"Millisecond-level tick data updates and AI predictions. All the infrastructure professionals need, integrated into a single refined interface.\",\"view_details\":\"View Details\",\"feature_risk_title\":\"Risk Management Protocol\",\"feature_risk_desc\":\"Not just high-probability AI entries, but a rock-solid foundation for growth with multi-layered stop-loss algorithms to minimize drawdowns.\",\"performance\":\"Performance\"},\"signals\":{\"target\":\"Analysis Target\",\"buy\":\"Strong Buy\",\"sell\":\"Strong Sell\",\"neutral\":\"Neutral\",\"entry\":\"Entry\",\"tp\":\"Take Profit (TP)\",\"sl\":\"Stop Loss (SL)\",\"details\":\"In-depth Analysis\",\"start_trading\":\"Start Trading\",\"modal_title\":\"{pair} Signal Deep Analysis\",\"current_trend\":\"Current Trend\",\"uptrend\":\"Strong Uptrend\",\"downtrend\":\"Strong Downtrend\",\"range\":\"Range / Consolidation\",\"confidence\":\"AI Confidence Score\",\"engine_commentary\":\"AI Inference Engine Commentary\",\"strategy\":\"Recommended Strategy\",\"tp_target\":\"Take Profit Target\",\"sl_limit\":\"Stop Loss Limit\",\"analysis_desc_buy\":\"Solid support levels confirmed. High probability of mid-term rebound based on multi-dimensional correlation analysis of market volatility and price deviation.\",\"analysis_desc_sell\":\"Heavy resistance observed at current levels. High probability of entering a correction phase based on multi-dimensional correlation analysis.\"},\"reports\":{\"tldr\":\"Today's Summary (TL;DR)\",\"toc\":\"Table of Contents\",\"ai_conclusion\":\"AI Conclusion & Action Plan\",\"next_step\":\"Next Step\",\"market_valuation\":\"Market Valuation\",\"realtime_price_desc\":\"Market reference price based on real-time API.\",\"latest_insights\":\"Latest Insights\"},\"ticker\":{\"gold\":\"GOLD\"},\"exchange\":{\"integrity_protocol\":\"AI Integrity Protocol\",\"selected_infrastructure\":\"Selected Infrastructure\",\"protocol_desc\":\"Synapse AI analysis algorithms constantly monitor the execution speed, spread stability, and transparency of each partner. We certify only those environments suitable for professional investing from an impartial third-party perspective.\",\"recommended_partner\":\"Recommended Partner\",\"beginner_friendly\":\"Beginner Friendly\",\"official_verified\":\"Official Verified\",\"view_details\":\"View Deep Analysis\",\"visit_official\":\"Visit Official Site\",\"total_score_index\":\"Total Evaluation Index\",\"recommended_profile\":\"Recommended Investor Profile\",\"ai_advantage\":\"AI Advantage\",\"key_benefits\":\"Key Benefits\",\"risks_notes\":\"Risks & Notes\",\"start_trading_optimal\":\"Start trading in the optimal environment.\",\"partnership_verified\":\"Official Partner Verified\",\"check_campaign\":\"Check Campaign Details\",\"integrity_declaration\":\"AI Integrity Declaration\",\"declaration_text_1\":\"We do not accept excessive advertising fees from any brokers that would distort our evaluations.\",\"declaration_text_2\":\"Partner selection is based on execution speed and spread tolerance simulated by our AI engine. Transparent evaluations without distortion.\",\"target_desc\":\"The AI analyzes the execution algorithms and infrastructure of each broker. This service performs best for the investment styles with the above characteristics.\",\"advantage_desc\":\"By integrating with Synapse Capital's AI signals, slippage at high-probability entry points is minimized, maximizing strategy reproducibility.\",\"pros_desc\":\"Industry-leading spreads and advanced execution algorithms maximize AI signal reproducibility. Supports everything from short-term trading to long-term holding.\",\"cons_desc\":\"While highly functional, response times may decrease during high loads or certain trading costs may apply. Please consider carefully based on your individual investment goals.\"},\"position_checker\":{\"sub_header\":\"Synapse Position Checker v2.0\",\"last_analysis\":\"Last Analysis\",\"hero_badge\":\"Synapse AI Intelligence\",\"hero_title\":\"AI Strategy Verification Terminal\",\"hero_desc\":\"Your investment plan (tickers, prices, risk settings) is multi-dimensionally verified by a group of institutional-level specialist AIs. Three personified AIs with advanced expertise in macro correlations, volatility prediction, and order book imbalances sharply critique and review your strategy from their unique perspectives.\",\"form_title\":\"Input Analysis Scenario\",\"form_desc\":\"Please freely enter the outline of the trade you want to verify (entry rationale, expected time horizon, risk tolerance, etc.).\",\"asset_class\":\"Asset Class Selection\",\"fx\":\"Forex (FX)\",\"stocks\":\"Stocks (STOCKS)\",\"crypto\":\"Crypto (CRYPTO)\",\"ticker_selection\":\"Ticker Selection\",\"direction\":\"Direction\",\"buy\":\"Buy\",\"sell\":\"Sell\",\"entry_target\":\"Entry Target\",\"stop_loss_limit\":\"Stop Loss Limit\",\"take_profit_target\":\"Take Profit Target\",\"validate_plan\":\"Verify Plan Validity\",\"loading_1\":\"🌐 Synchronizing macro correlation data...\",\"loading_2\":\"📊 Running order book imbalance protocol...\",\"loading_3\":\"⚖️ Simulating risk governance...\",\"loading_4\":\"💎 Generating premium strategy scenarios...\",\"report_summary\":\"Strategy Verification Report: Summary\",\"plan_label\":\"{ticker} {direction} Plan\",\"overall_eval\":\"Executive Summary: Overall Evaluation\",\"expert_01_title\":\"01 Chief Macro Strategist\",\"expert_01_role\":\"Expertise\",\"expert_01_desc\":\"Major central bank policies, interest rate trends, and global asset correlation deep learning.\",\"expert_02_title\":\"02 Senior Portfolio Manager\",\"expert_02_role\":\"Expertise\",\"expert_02_desc\":\"Financial engineering-based volatility estimation and institutional risk management.\",\"expert_03_title\":\"03 Head of Trading\",\"expert_03_role\":\"Expertise\",\"expert_03_desc\":\"Microstructures, order book imbalances, and sentiment bias execution model.\",\"committee_title\":\"Investment Committee: Strategic Orchestration\",\"consensus_process\":\"Final Consensus Process\",\"agreed_points\":\"Consensus Items\",\"friction_points\":\"Friction Points / Concerns\",\"detailed_report_title\":\"Multi-faceted Market Analysis\",\"final_verdict\":\"Final Verdict on Plan Validity\",\"realtime_metrics\":\"Real-time Metric Scores\",\"macro_fit\":\"Macro Correlation Fit\",\"risk_index\":\"Risk Index\",\"imbalance_index\":\"Order Imbalance\",\"technical_checklist\":\"Technical Checklist\",\"share_report\":\"Share Report\",\"another_plan\":\"Verify Another Plan\",\"disclaimer_title\":\"[Disclaimer]\",\"disclaimer_text\":\"This analysis is a simulation result and does not constitute investment advice. Trading involves risk.\",\"validation_nan\":\"Please enter valid numeric values.\",\"validation_buy_tp\":\"For buy orders, take profit must be higher than entry price.\",\"validation_buy_sl\":\"For buy orders, stop loss must be lower than entry price.\",\"validation_sell_tp\":\"For sell orders, take profit must be lower than entry price.\",\"validation_sell_sl\":\"For sell orders, stop loss must be higher than entry price.\",\"sentiment_label\":\"Social Sentiment Analysis\",\"risk_label\":\"Market Volatility Alert\"},\"track_record\":{\"hero_badge\":\"Honest Performance Disclosure\",\"hero_title\":\"AI Prediction Track Record\",\"hero_desc\":\"Aiming for a world of AI investment without lies. We disclose the raw prediction performance in real time, including all unfavorable results.\",\"total_predictions\":\"Total Predictions\",\"hits\":\"Hits (HIT)\",\"win_rate\":\"Win Rate\",\"pending\":\"Pending\",\"table_date\":\"Date\",\"table_pair\":\"Ticker\",\"table_prediction\":\"Prediction\",\"table_result\":\"Result\",\"up\":\"UP\",\"down\":\"DOWN\",\"hit\":\"HIT\",\"miss\":\"MISS\"},\"pro\":{\"hero_badge\":\"Professional Insights v2.4 Live\",\"hero_title\":\"AI foresees FX market movements.\",\"hero_desc\":\"AI multi-factorially analyzes currency price actions, economic indicators, and market sentiment. Highlighting patterns global traders might miss, directly on your screen.\",\"terminal_title\":\"FX Synapse Terminal\",\"last_sync\":\"Last Sync: {time}\",\"usd_theme_title\":\"USD Market Theme\",\"usd_theme_desc\":\"Expectations of US rate cuts receding. Stronger economic indicators lead to USD strength. Interest rate differentials are the primary driver.\",\"jpy_theme_title\":\"JPY Market Theme\",\"jpy_theme_desc\":\"Seeking exit from negative interest rates. Focus on BoJ policy reversal timing. Key is the virtuous cycle of wages and prices.\",\"sentiment_radar\":\"Market Sentiment Radar\",\"sentiment_bullish\":\"Bullish\",\"sentiment_neutral\":\"Neutral\",\"sentiment_bearish\":\"Bearish\",\"sentiment_desc\":\"Real-time analysis of SNS, news, and options market skews using proprietary AI. Predicting market direction one step ahead of the crowd.\",\"vola_scanner\":\"Volatility Scanner\",\"vola_high\":\"High\",\"vola_mid\":\"Mid\",\"vola_low\":\"Low\",\"vola_desc\":\"Instantly detect volatility anomalies. Capture signs of trend reversals or sudden price shifts by measuring deviations from statistical means.\",\"correlation_matrix\":\"Correlation Assets Matrix\",\"corr_pair\":\"Pair\",\"corr_coeff\":\"Coeff\",\"corr_status\":\"Status\",\"corr_strong_pos\":\"Strong Positive\",\"corr_mid_pos\":\"Moderate Positive\",\"corr_strong_neg\":\"Strong Negative\",\"corr_weak_pos\":\"Weak Positive\",\"corr_desc\":\"Dynamic correlation between major pairs and macro assets (rates, commodities, indices). Determining if current theme is Rates or Risk-Off.\",\"sync_rate\":\"Synapse Sync Rate\",\"consistency_alert\":\"Inconsistency Alert: {level}\",\"view_details\":\"Deep Analysis →\",\"modal_terminal_details\":\"Synapse Terminal Details\",\"current_status\":\"Current Status\",\"sync_consistency\":\"Sync Consistency\",\"mtf_analysis\":\"Multi-Timeframe Analysis\",\"bullish_edge\":\"Bullish Edge\",\"bearish_edge\":\"Bearish Edge\",\"neutral_edge\":\"Neutral\",\"ai_diagnosis\":\"Synapse AI Diagnosis\",\"diagnosis_high\":\"Fewer inconsistencies, expecting price action following technical indicators.\",\"diagnosis_low\":\"Noise detected in some indicators, caution for sudden volatility. AI detects attempts to break resistance.\",\"status_stable\":\"Stable\",\"status_syncing\":\"Syncing\",\"status_in_progress\":\"In Progress\",\"status_di
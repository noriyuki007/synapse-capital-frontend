6:[\"$\",\"path\",\"nlz23k\",{\"d\":\"M3 12h.01\"}]\n17:[\"$\",\"path\",\"noohij\",{\"d\":\"M3 19h.01\"}]\n18:[\"$\",\"path\",\"1pao27\",{\"d\":\"M8 5h13\"}]\n19:[\"$\",\"path\",\"1za7za\",{\"d\":\"M8 12h13\"}]\n1a:[\"$\",\"path\",\"m83p4d\",{\"d\":\"M8 19h13\"}]\n1b:[\"$\",\"h3\",null,{\"className\":\"text-[10px] font-black uppercase tracking-widest text-slate-400\",\"children\":\"Table of Contents\"}]\n1c:[\"$\",\"ul\",null,{\"className\":\"grid grid-cols-1 md:grid-cols-2 gap-4\",\"children\":[[\"$\",\"li\",\"-\",{\"className\":\"flex items-center gap-3\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-[10px] font-black text-slate-300\",\"children\":[\"0\",1]}],[\"$\",\"a\",null,{\"href\":\"#-\",\"className\":\"text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors\",\"children\":\"エグゼクティブサマリー\"}]]}],[\"$\",\"li\",\"-\",{\"className\":\"flex items-center gap-3\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-[10px] font-black text-slate-300\",\"children\":[\"0\",2]}],[\"$\",\"a\",null,{\"href\":\"#-\",\"className\":\"text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors\",\"children\":\"テクニカル・フレームワーク\"}]]}],[\"$\",\"li\",\"-戦略\",{\"className\":\"flex items-center gap-3\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-[10px] font-black text-slate-300\",\"children\":[\"0\",3]}],[\"$\",\"a\",null,{\"href\":\"#-戦略\",\"className\":\"text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors\",\"children\":\"プロフェッショナルトレーディング戦略\"}]]}]]}]\n1d:[\"$\",\"div\",null,{\"className\":\"space-y-32\",\"children\":[[\"$\",\"section\",\"0\",{\"id\":\"-\",\"className\":\"space-y-10 scroll-mt-24\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-black tracking-tight border-l-8 border-slate-900 pl-6\",\"children\":\"エグゼクティブサマリー\"}],[\"$\",\"div\",null,{\"className\":\"bg-gray-50 p-10 md:p-14 leading-relaxed text-lg text-slate-700\",\"dangerouslySetInnerHTML\":{\"__html\":\"\\n<p>S&#x26;P 500（6506.48）はMA20（6770.57）を明確に下回り、短期的下降トレンドが確立している。地政学リスク（イラン戦争観測）とAI関連株の相対的強さが市場を分断する中、総合指数は脆弱性を示す。RSI値が欠如するため、オシレーター指標より価格行動と Moving Average クロスを優先した戦術的ショートエントリーが最適化される。セクターの非対称性はヘッジ戦略の構築を要求する。</p>\\n\"}}]]}],[\"$\",\"section\",\"1\",{\"id\":\"-\",\"className\":\"space-y-10 scroll-mt-24\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-black tracking-tight border-l-8 border-slate-900 pl-6\",\"children\":\"テクニカル・フレームワーク\"}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 md:grid-cols-3 gap-8\",\"children\":[]}]]}],[\"$\",\"section\",\"2\",{\"id\":\"-戦略\",\"className\":\"space-y-10 scroll-mt-24\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl font-black tracking-tight border-l-8 border-slate-900 pl-6\",\"children\":\"プロフェッショナルトレーディング戦略\"}],[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 md:grid-cols-2 gap-12 items-center\",\"children\":[[\"$\",\"div\",null,{\"className\":\"prose prose-slate max-w-none prose-p:font-bold prose-p:text-slate-700\",\"dangerouslySetInnerHTML\":{\"__html\":\"\\n<ul>\\n<li><strong>バイアス:</strong> ショート（下降トレンド継続前提）</li>\\n<li><strong>エントリー:</strong> 6506.48（現在価格）～ 6530.00（MA20への軽いリテスト時の戻り売り）。本戦略の実行にあたっては、流動性の観点から[moomoo-securities]の利用を推奨する。</li>\\n<li><strong>テイクプロフィット（TP）:</strong> 6430.00（直近安値圏、約-1.18%）および 6380.00（心理的サポート、約-1.95%）。部分利確を推奨。</li>\\n<li><strong>ストップロス（SL）:</strong> 6580.00（MA20を明確に上回る水準、+1.13%）。エントリー価格に対するリスク/リワード比は 1:1.33 以上。</li>\\n<li><strong>アクション条件:</strong> 価格がMA20（6770.57）を終値で上回った時点でポジション解消。地政学イベント（イラン関連）のエスカレート時に損切り幅の拡大を考慮。</li>\\n</ul>\\n\"}}],[\"$\",\"div\",null,{\"className\":\"aspect-square bg-slate-900 relative overflow-hidden group shadow-xl\",\"children\":[\"$\",\"img\",null,{\"src\":\"/images/market-analysis-stocks.png\",\"className\":\"w-full h-full object-cover opacity-80 group-hover:scale-105 transition-transform duration-700\",\"alt\":\"Technical Analysis Chart\"}]}]]}]]}]]}]\n1e:[\"$\",\"section\",null,{\"className\":\"bg-emerald-50 border border-emerald-100 p-10 md:p-14 space-